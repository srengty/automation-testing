<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Lab03 Automation Framework Test Suite" verbose="1">
    
    <parameter name="browser" value="chrome"/>
    <parameter name="environment" value="local"/>
    <parameter name="headless" value="false"/>
    
    <!-- Global test configuration -->
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>
    
    <!-- UI Tests -->
    <test name="UI Tests" preserve-order="true">
        <parameter name="test.type" value="ui"/>
        <classes>
            <class name="lab03.ui.tests.LoginPageTests"/>
        </classes>
    </test>
    
    <!-- API Tests -->
    <test name="API Tests" preserve-order="true" parallel="methods" thread-count="3">
        <parameter name="test.type" value="api"/>
        <classes>
            <class name="lab03.api.tests.UserAPITests"/>
        </classes>
    </test>

</suite>